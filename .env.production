# Production environment — used by `npm run build`.
# Vite loads .env.production when --mode is omitted for build.

# Production backend on Render.
VITE_API_BASE_URL=https://vietcast-backend.onrender.com
VITE_WS_BASE_URL=wss://vietcast-backend.onrender.com

# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console.
# IMPORTANT: this MUST be the WEB application client ID (NOT Android /
# iOS). The backend's `vietcast.google.client-id` env var must match
# this exact value or POST /api/v1/auth/google will 401.
VITE_GOOGLE_CLIENT_ID=783559355722-s6176mc03l424sv6119ofrs9ho8g107b.apps.googleusercontent.com