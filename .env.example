# ============================================================================
# VietCast Frontend - Environment Variables
# Copy this file to .env.production / .env.development and edit values.
#
# Vite will inline values prefixed with `VITE_` at build time into the bundle.
# Electron reads the same env vars from the main process (without VITE_ prefix)
# so the two stay in sync.
#
# NEVER commit real production secrets here.
# ============================================================================

# Backend REST API (Spring Boot)
# This is the ONLY VITE_API_BASE_URL declaration in the file.
# Used by Vite at build time via `import.meta.env.VITE_API_BASE_URL`.
# Falls back to https://vietcast-backend.onrender.com in src/config.js
# when this variable is missing.
VITE_API_BASE_URL=https://vietcast-backend.onrender.com

# WebSocket endpoint (optional — leave empty to derive from API base URL).
VITE_WS_BASE_URL=wss://vietcast-backend.onrender.com

# Application
VITE_APP_VERSION=1.0.0

# Env passed to Electron at runtime (overrides defaults in electron/main.js
# when set). These can be left blank — the defaults will be used.
# VIETCAST_API_BASE_URL=https://vietcast-backend.onrender.com