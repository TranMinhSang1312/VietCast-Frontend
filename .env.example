# ============================================================================
# VietCast Web - Environment Variables
# Copy this file to .env.production / .env.development and edit values.
#
# Vite will inline values prefixed with `VITE_` at build time into the bundle.
# ============================================================================

# Backend REST API (Spring Boot)
# Used at build time via `import.meta.env.VITE_API_BASE_URL`.
# Falls back to https://vietcast-backend.onrender.com in src/config.js
# when this variable is missing.
VITE_API_BASE_URL=https://vietcast-backend.onrender.com

# WebSocket endpoint (optional — leave empty to derive from API base URL).
VITE_WS_BASE_URL=wss://vietcast-backend.onrender.com

# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console.
# This is the SAME client ID you registered on
# https://console.cloud.google.com/apis/credentials. It MUST also be
# configured on the Spring Boot backend (env var GOOGLE_CLIENT_ID →
# vietcast.google.client-id) so the server-side `GoogleIdTokenVerifier`
# can validate incoming idTokens against it.
#
# Get one from:
#   1. Google Cloud Console → APIs & Services → Credentials
#   2. Create credentials → OAuth client ID → Application type: Web app
#   3. Add the dev origin (http://localhost:3000) and your production
#      domain to "Authorized JavaScript origins".
#   4. Copy the client ID string here AND onto the backend env.
VITE_GOOGLE_CLIENT_ID=